{
  "name": "@chronoview/ui",
  "version": "0.1.0-alpha.0",
  "description": "shadcn-style UI components for ChronoView",
  "license": "MIT",
  "author": "myalim",
  "homepage": "https://github.com/myalim/chronoview#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/myalim/chronoview.git",
    "directory": "packages/ui"
  },
  "bugs": "https://github.com/myalim/chronoview/issues",
  "keywords": [
    "chronoview",
    "react",
    "schedule",
    "timeline",
    "calendar",
    "ui",
    "components"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tailwindcss -i src/styles/input.css -o dist/styles.css --minify",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chronoview/core": "workspace:*",
    "@chronoview/react": "workspace:*"
  },
  "peerDependencies": {
    "@floating-ui/react": ">=0.27.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.0.0"
  }
}
